# ───────────────────────────────────────────────────────────────
# Database (Supabase PostgreSQL or any standard PostgreSQL)
# ───────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string → URI
# Use the "Connection pooling" (port 6543, pgbouncer) URL for the app,
# and the "Direct connection" (port 5432) URL for Prisma migrations.
#
# Format:
#   postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
#
# Example (placeholders only — DO NOT commit real credentials):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?schema=public&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# ───────────────────────────────────────────────────────────────
# Auth
# ───────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="12h"

# ───────────────────────────────────────────────────────────────
# Server
# ───────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN="http://localhost:5173,http://localhost:8080"
