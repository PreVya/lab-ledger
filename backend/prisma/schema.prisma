// Prisma schema — Pathology Lab
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  receptionist
  technician
  doctor
}

enum Sex {
  M
  F
  O
}

enum PaymentMode {
  cash
  upi
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  fullName     String
  role         Role
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TestCatalog {
  id              String       @id @default(uuid())
  name            String       @unique
  rate            Decimal      @db.Decimal(10, 2)
  outsourced      Boolean      @default(false)
  outsourcedLab   String?
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  patientTests    PatientTest[]
}

model Patient {
  id              String        @id @default(uuid())
  dailySerial     Int
  entryDate       DateTime      @db.Date
  name            String
  mobile          String
  age             Int
  sex             Sex
  referredDoctor  String?
  notes           String?

  // Payment — exact fields, do not change
  total           Decimal       @db.Decimal(10, 2) @default(0)
  discount        Decimal       @db.Decimal(10, 2) @default(0)
  net             Decimal       @db.Decimal(10, 2) @default(0)
  advanceCash     Decimal       @db.Decimal(10, 2) @default(0)
  advanceUpi      Decimal       @db.Decimal(10, 2) @default(0)
  advancePaidOn   DateTime?
  balance         Decimal       @db.Decimal(10, 2) @default(0)
  balanceCash     Decimal       @db.Decimal(10, 2) @default(0)
  balanceUpi      Decimal       @db.Decimal(10, 2) @default(0)
  balancePaidOn   DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdById     String?

  tests           PatientTest[]

  @@unique([entryDate, dailySerial])
  @@index([mobile])
  @@index([name])
  @@index([entryDate])
}

model PatientTest {
  id            String      @id @default(uuid())
  patientId     String
  testId        String
  rateAtEntry   Decimal     @db.Decimal(10, 2)
  patient       Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  test          TestCatalog @relation(fields: [testId], references: [id])

  @@index([patientId])
}

model DailyLedger {
  id              String   @id @default(uuid())
  date            DateTime @unique @db.Date
  openingBalance  Decimal  @db.Decimal(12, 2)
  closingBalance  Decimal  @db.Decimal(12, 2) @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  date        DateTime @db.Date
  description String
  amount      Decimal  @db.Decimal(10, 2)
  mode        PaymentMode @default(cash)
  createdAt   DateTime @default(now())

  @@index([date])
}
