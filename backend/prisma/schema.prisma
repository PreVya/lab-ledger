// Prisma schema — Pathology Lab
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  receptionist
  technician
  doctor
}

enum Sex {
  M
  F
  O
}

enum PaymentMode {
  cash
  upi
  card
  other
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  fullName     String
  role         Role
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TestCatalog {
  id              String       @id @default(uuid())
  // Name is NOT globally unique anymore. Uniqueness is enforced via a
  // functional index over (lower(trim(name)), coalesce(lower(trim(outsourcedLab)), 'INHOUSE'))
  // created in migration phase_1_75_reception_book_alignment/migration.sql.
  name            String
  rate            Decimal      @db.Decimal(10, 2)
  outsourced      Boolean      @default(false)
  outsourcedLab   String?
  // testCode is applicable only for outsourced tests (e.g. Metropolis M1234,
  // Lupin L9876). Nullable for now — Phase 1.90.
  testCode        String?      @db.VarChar(100)
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  patientTests    PatientTest[]

  @@index([name])
  @@index([testCode])
}

model Patient {
  id              String        @id @default(uuid())
  dailySerial     Int
  financialYear   String
  registerNumber  Int
  entryDate       DateTime      @db.Date
  name            String
  mobile          String
  // Legacy column kept for back-compat (in years). New code reads ageValue/ageUnit.
  age             Int
  ageValue        Int?
  ageUnit         String        @default("years")
  sex             Sex
  referredDoctor  String?
  notes           String?

  total           Decimal       @db.Decimal(10, 2) @default(0)
  discount        Decimal       @db.Decimal(10, 2) @default(0)
  net             Decimal       @db.Decimal(10, 2) @default(0)
  advanceCash     Decimal       @db.Decimal(10, 2) @default(0)
  advanceUpi      Decimal       @db.Decimal(10, 2) @default(0)
  advancePaidOn   DateTime?
  balance         Decimal       @db.Decimal(10, 2) @default(0)
  balanceCash     Decimal       @db.Decimal(10, 2) @default(0)
  balanceUpi      Decimal       @db.Decimal(10, 2) @default(0)
  balancePaidOn   DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdById     String?

  tests           PatientTest[]
  payments        Payment[]
  appointments    Appointment[]

  @@unique([entryDate, dailySerial])
  @@unique([financialYear, registerNumber])
  @@index([mobile])
  @@index([name])
  @@index([entryDate])
  @@index([financialYear])
}

model PatientTest {
  id            String      @id @default(uuid())
  patientId     String
  testId        String
  rateAtEntry   Decimal     @db.Decimal(10, 2)
  patient       Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  test          TestCatalog @relation(fields: [testId], references: [id])

  @@index([patientId])
}

model DailyLedger {
  // openingBalance/closingBalance are CASH balances (post Phase 1.75).
  // UPI/card collection is tracked separately via Payment rows and does not
  // affect physical cash balance carried day-to-day.
  id              String   @id @default(uuid())
  date            DateTime @unique @db.Date
  openingBalance  Decimal  @db.Decimal(12, 2)
  closingBalance  Decimal  @db.Decimal(12, 2) @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  date        DateTime @db.Date
  description String
  amount      Decimal  @db.Decimal(10, 2)
  mode        PaymentMode @default(cash)
  createdAt   DateTime @default(now())

  @@index([date])
}

enum PaymentKind {
  advance
  balance
}

/// Manual "added cash" — extra cash physically added to the drawer to keep
/// enough change money on hand. Increases closing cash balance only; does
/// NOT count as patient collection or billing.
model CashAdded {
  id          String   @id @default(uuid())
  date        DateTime @db.Date
  amount      Decimal  @db.Decimal(10, 2)
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([createdById])
}

model Payment {
  id         String      @id @default(uuid())
  patientId  String
  date       DateTime    @db.Date
  kind       PaymentKind
  mode       PaymentMode
  amount     Decimal     @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime    @default(now())
  createdById String?

  patient    Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([date])
  @@index([kind, date])
}

/// Manual end-of-day cash taken away by the doctor/owner.
/// Reduces closing cash balance; multiple per day allowed.
model CashHandover {
  id          String   @id @default(uuid())
  date        DateTime @db.Date
  amount      Decimal  @db.Decimal(10, 2)
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

// ============================================================================
// PHASE 2 — Appointments + Employees + Attendance + Salary
// ============================================================================

enum AppointmentStatus {
  scheduled
  sample_collected
  cancelled
  rescheduled
  no_show
}

enum AttendanceStatus {
  present
  absent
  half_day
  leave
}

/// Generic file registry. Actual bytes live in Supabase Storage; only metadata
/// is stored here.
model StoredFile {
  id             String   @id @default(uuid())
  bucket         String
  path           String
  originalName   String
  mimeType       String
  size           Int
  documentType   String
  entityType     String
  entityId       String?
  uploadedById   String?
  createdAt      DateTime @default(now())

  employees      Employee[] @relation("EmployeeAadhaar")

  @@index([entityType, entityId])
  @@index([documentType])
}

/// Scheduled procedures (FNAC, Pap smear, etc). NEVER auto-creates Patient
/// rows. Manual conversion only, via link-patient endpoint after a Patient
/// row has been created from the prefilled patient form.
model Appointment {
  id                String            @id @default(uuid())
  name              String
  mobile            String
  ageValue          Int               @default(0)
  ageUnit           String            @default("years")
  sex               Sex
  referredDoctor    String?
  procedure         String
  appointmentDate   DateTime          @db.Date
  appointmentTime   String?
  status            AppointmentStatus @default(scheduled)
  notes             String?
  linkedPatientId   String?
  linkedPatient     Patient?          @relation(fields: [linkedPatientId], references: [id], onDelete: SetNull)
  createdById       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([appointmentDate])
  @@index([status])
  @@index([linkedPatientId])
}

model Employee {
  id                 String        @id @default(uuid())
  name               String
  mobile             String?
  designation        String?
  monthlySalary      Decimal       @db.Decimal(10, 2) @default(0)
  active             Boolean       @default(true)
  /// When true, employee is auto-credited "present" for every working day
  /// without manual attendance entry (e.g. permanent staff Prerana, Gayatri).
  /// Holidays/Sundays do not reduce their salary either.
  alwaysPresent      Boolean       @default(false)
  linkedUserId       String?
  aadhaarDocumentId  String?
  aadhaarDocument    StoredFile?   @relation("EmployeeAadhaar", fields: [aadhaarDocumentId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  attendance         Attendance[]
  salaryAdvances     SalaryAdvance[]

  @@index([active])
}

/// Working-day holidays. Sundays are treated implicitly as holidays and do
/// not require a row; entries here are for custom holidays (public/private).
/// Salary logic does not deduct pay for holidays.
model Holiday {
  id          String   @id @default(uuid())
  date        DateTime @unique @db.Date
  name        String
  type        String   @default("custom") // "custom" | "sunday" (rare — usually implicit)
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
}

model Attendance {
  id          String           @id @default(uuid())
  employeeId  String
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime         @db.Date
  status      AttendanceStatus
  notes       String?
  markedById  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([date])
}

model SalaryAdvance {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  amount      Decimal  @db.Decimal(10, 2)
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId, date])
}
